# ==========================================
# Unity 核心忽略项 (绝对不能上传的体积怪兽)
# ==========================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# 内存抓取和录屏文件 (体积巨大且没必要版本控制)
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ==========================================
# 自动生成的项目/代码编辑器文件 (VS Code / Visual Studio)
# ==========================================
.vs/
.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 为这些生成的 meta 文件也需要忽略
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ==========================================
# 崩溃报告与打包产物
# ==========================================
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties
*.dat

# ==========================================
# 操作系统自动生成的隐藏垃圾文件 (Windows & Mac)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db